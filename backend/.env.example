# ── Supabase (opcional — sin esto usa JSON local) ─────────────────
# Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Settings → API → service_role key  (¡NO expongas esta key en el frontend!)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── PostgreSQL directo (alternativa a Supabase) ───────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/agrosense

# JWT Auth
JWT_SECRET=your_256_bit_secret_key_here
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://agrosense.cyberbotlabs.io

# Email (alertas)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@cyberbotlabs.io
SMTP_PASS=your_app_password

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_FREE=50
RATE_LIMIT_MAX_PRO=500
